@model ToDoList.Models.Auth.RegisterViewModel
@{
    ViewData["Title"] = Auth.Registration_Page_Title;
}

<div class="auth-page">
    <article class="create-card auth-card" aria-labelledby="register-heading">
        <header class="create-card__header">
            <h1 id="register-heading" class="create-card__title">@Auth.Registration_Header_Title</h1>
            <p class="create-card__lead">@Auth.Registration_Header_Lead</p>
        </header>

        <form class="create-form auth-form"
              asp-action="Registration"
              asp-controller="Auth"
              method="post"
              enctype="multipart/form-data"
              novalidate
              data-login-taken-message="@Auth.Validation_LoginTaken">
            <div class="form-field login-check-block">
                <label class="form-field__label" for="auth-login">@Auth.Registration_Label_Login</label>
                <div class="login-check-block__inner">
                    <input
                        asp-for="Login"
                        id="auth-login"
                        class="form-field__input"
                        placeholder="@Auth.Registration_Placeholder_Login"
                        autocomplete="username"
                        maxlength="100" />
                    <span class="login-check-icon login-check-icon--wait" hidden aria-hidden="true">…</span>
                    <span class="login-check-icon login-check-icon--ok" hidden aria-hidden="true">✓</span>
                    <span class="login-check-icon login-check-icon--deny" hidden aria-hidden="true">✗</span>
                </div>
                <p class="login-check-message" id="login-check-message" hidden></p>
                @Html.ValidationMessageFor(x => x.Login)
            </div>

            <div class="form-field form-field--avatar">
                <span class="form-field__label" id="auth-avatar-label">@Auth.Registration_Label_Avatar <span class="form-field__hint">@Auth.Registration_Avatar_Optional</span></span>
                <div class="profile-avatar-block profile-avatar-block--register" aria-labelledby="auth-avatar-label">
                    <img id="register-avatar-preview-image"
                         class="profile-avatar profile-avatar--large register-avatar-preview register-avatar-preview--hidden"
                         alt="@Auth.Registration_Avatar_Preview_Alt" />
                    <span id="register-avatar-preview-placeholder"
                          class="profile-avatar profile-avatar--large profile-avatar--placeholder"
                          aria-hidden="true">?</span>
                </div>
                <input
                    type="file"
                    id="auth-avatar"
                    name="avatar"
                    class="form-field__input form-field__input--file"
                    accept=".jpg,.jpeg,.png,.webp,.gif,image/jpeg,image/png,image/webp,image/gif" />
            </div>

            <div class="form-field">
                <label class="form-field__label" for="auth-password">@Auth.Registration_Label_Password</label>
                <input
                    asp-for="Password"
                    id="auth-password"
                    type="password"
                    class="form-field__input"
                    placeholder="@Auth.Registration_Placeholder_Password"
                    autocomplete="new-password"
                    maxlength="100" />
                @Html.ValidationMessageFor(x => x.Password)
            </div>
            <div class="form-field">
                <label class="form-field__label" for="auth-password-confirm">@Auth.Registration_Label_ConfirmPassword</label>
                <input asp-for="DoubleCheckPassword"
                       id="auth-password-confirm"
                       type="password"
                       class="form-field__input"
                       placeholder="@Auth.Registration_Placeholder_ConfirmPassword"
                       autocomplete="new-password"
                       maxlength="100" />
                @Html.ValidationMessageFor(x => x.DoubleCheckPassword)
            </div>

            <div class="create-form__actions auth-form__actions">
                <button type="submit" class="create-btn create-btn--primary auth-form__submit">@Auth.Registration_Button_Submit</button>
            </div>
        </form>

        <p class="auth-switch">
            @Auth.Registration_Switch_Text
            <a class="auth-switch__link" asp-controller="Auth" asp-action="Login">@Auth.Registration_Switch_Link</a>
        </p>
    </article>
</div>

@section Scripts {
    <script src="~/js/registration.js" asp-append-version="true"></script>
    <script>
        (function () {
            var loginInput = document.getElementById('auth-login');
            var fileInput = document.getElementById('auth-avatar');
            var placeholder = document.getElementById('register-avatar-preview-placeholder');
            var previewImage = document.getElementById('register-avatar-preview-image');
            var previewUrl = null;

            function updatePlaceholder() {
                var value = (loginInput && loginInput.value || '').trim();
                placeholder.textContent = value ? value.charAt(0).toUpperCase() : '?';
            }

            function clearPreviewUrl() {
                if (previewUrl) {
                    URL.revokeObjectURL(previewUrl);
                    previewUrl = null;
                }
            }

            if (loginInput) {
                loginInput.addEventListener('input', updatePlaceholder);
                updatePlaceholder();
            }

            if (fileInput) {
                fileInput.addEventListener('change', function () {
                    clearPreviewUrl();

                    var file = fileInput.files && fileInput.files[0];
                    if (!file) {
                        previewImage.classList.add('register-avatar-preview--hidden');
                        placeholder.hidden = false;
                        return;
                    }

                    previewUrl = URL.createObjectURL(file);
                    previewImage.src = previewUrl;
                    previewImage.classList.remove('register-avatar-preview--hidden');
                    placeholder.hidden = true;
                });
            }
        })();
    </script>
}
