@using ToDoList.Data.Enums
@using ToDoList.Models.Dtos
@model (ToDoTaskDto Task, bool IsFirst, bool IsLast)

@{
    var task = Model.Task;

    string GetPriorityLabel(Priority priority) => priority switch
    {
        Priority.High => "Срочная",
        Priority.Medium => "Средняя",
        Priority.Low => "Лёгкая",
        _ => priority.ToString()
    };

    string GetPriorityPillClass(Priority priority) => priority switch
    {
        Priority.High => "task-card__pill--priority-high",
        Priority.Medium => "task-card__pill--priority-medium",
        Priority.Low => "task-card__pill--priority-low",
        _ => string.Empty
    };

    var cardClass = task.IsImportant
        ? "task-card task-card--important"
        : $"task-card task-card--priority-{task.Priority.ToString().ToLower()}";
}

<li class="@cardClass" data-task-id="@task.Id">
    <div class="task-card__head">
        <h2 class="task-card__title">@task.Name</h2>
        <div class="task-card__actions">
            <div class="task-card__order" role="group" aria-label="Порядок задачи «@task.Name»">
                <button type="button"
                        class="task-card__order-btn task-card__order-btn--up"
                        title="Поднять выше"
                        aria-label="Поднять задачу «@task.Name» выше"
                        @(Model.IsFirst ? "disabled" : null)>
                    <svg class="task-card__order-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
                        <path d="M3.5 9L7 5.5L10.5 9" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
                <button type="button"
                        class="task-card__order-btn task-card__order-btn--down"
                        title="Опустить ниже"
                        aria-label="Опустить задачу «@task.Name» ниже"
                        @(Model.IsLast ? "disabled" : null)>
                    <svg class="task-card__order-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
                        <path d="M3.5 5L7 8.5L10.5 5" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
            </div>
            @if (task.IsImportant)
            {
                <span class="task-card__badge" title="Важная">!</span>
            }
            @await Html.PartialAsync("_TaskCompleteForm", (task.Id, task.Name))
            @await Html.PartialAsync("_TaskDeleteForm", (task.Id, "ToDoList", task.Name))
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(task.Description))
    {
        <p class="task-card__description">@task.Description</p>
    }

    <ul class="task-card__meta">
        <li>
            <span class="task-card__meta-label">Важность</span>
            <span class="task-card__pill @GetPriorityPillClass(task.Priority)">@GetPriorityLabel(task.Priority)</span>
        </li>
        <li>
            <span class="task-card__meta-label">Статус</span>
            <span class="task-card__pill task-card__pill--active">Активна</span>
        </li>
        @if (!string.IsNullOrWhiteSpace(task.Category))
        {
            <li>
                <span class="task-card__meta-label">Категория</span>
                <span>@task.Category</span>
            </li>
        }
        @if (task.DeadlineAt.HasValue)
        {
            var deadlineSoon = task.DeadlineAt.Value - DateTime.Now < TimeSpan.FromHours(24) && task.DeadlineAt.Value > DateTime.Now;
            <li>
                <span class="task-card__meta-label">Срок</span>
                <span class="@(deadlineSoon ? "task-card__deadline--soon" : null)">@task.DeadlineAt.Value.ToString("dd.MM.yyyy, HH:mm")</span>
            </li>
        }
    </ul>
</li>
