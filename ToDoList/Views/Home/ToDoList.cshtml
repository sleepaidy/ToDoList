@{
    ViewData["Title"] = "Все задачи";
}

<div class="todo-app-page">
    <article class="page-card" aria-labelledby="all-tasks-heading">
        <header class="page-card__header">
            <h1 id="all-tasks-heading" class="page-card__title">Все задачи</h1>
            <p class="page-card__lead">Список дел, созданных на странице «Новая задача»</p>
            <span class="page-card__count">3</span>
        </header>

        <ul class="task-list">
            <li class="task-card task-card--important">
                <div class="task-card__head">
                    <h2 class="task-card__title">Подготовить отчёт</h2>
                    <span class="task-card__badge" title="Важная">!</span>
                </div>
                <p class="task-card__description">Собрать данные за квартал и оформить презентацию.</p>
                <ul class="task-card__meta">
                    <li>
                        <span class="task-card__meta-label">Приоритет</span>
                        <span class="task-card__pill task-card__pill--priority-high">Высокий</span>
                    </li>
                    <li>
                        <span class="task-card__meta-label">Категория</span>
                        <span>Работа</span>
                    </li>
                    <li>
                        <span class="task-card__meta-label">Срок</span>
                        <span>30.05.2026, 18:00</span>
                    </li>
                </ul>
            </li>
            <li class="task-card task-card--priority-medium">
                <div class="task-card__head">
                    <h2 class="task-card__title">Записаться к врачу</h2>
                </div>
                <p class="task-card__description">Терапевт, четверг после обеда.</p>
                <ul class="task-card__meta">
                    <li>
                        <span class="task-card__meta-label">Приоритет</span>
                        <span class="task-card__pill task-card__pill--priority-medium">Средний</span>
                    </li>
                    <li>
                        <span class="task-card__meta-label">Категория</span>
                        <span>Здоровье</span>
                    </li>
                    <li>
                        <span class="task-card__meta-label">Срок</span>
                        <span>02.06.2026, 14:30</span>
                    </li>
                </ul>
            </li>
            <li class="task-card task-card--priority-low">
                <div class="task-card__head">
                    <h2 class="task-card__title">Разобрать почту</h2>
                </div>
                <p class="task-card__description">Ответить на письма за неделю, удалить рассылки.</p>
                <ul class="task-card__meta">
                    <li>
                        <span class="task-card__meta-label">Приоритет</span>
                        <span class="task-card__pill task-card__pill--priority-low">Низкий</span>
                    </li>
                    <li>
                        <span class="task-card__meta-label">Категория</span>
                        <span>Работа</span>
                    </li>
                </ul>
            </li>
        </ul>
    </article>
</div>
