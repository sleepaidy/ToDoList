@model (int Id, string TaskName)

<form asp-controller="Home"
      asp-action="Complete"
      method="post"
      class="task-card__complete-form">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit"
            class="task-card__complete-btn"
            title="@Shared.Task_Complete_Title"
            aria-label="@string.Format(Shared.Task_Complete_AriaLabel, Model.TaskName)">
        <span aria-hidden="true">✓</span>
    </button>
</form>
