@model ToDoList.Models.Auth.LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<div class="auth-page">
    <article class="create-card auth-card" aria-labelledby="login-heading">
        <header class="create-card__header">
            <h1 id="login-heading" class="create-card__title">Вход</h1>
            <p class="create-card__lead">Войдите, чтобы управлять своими задачами.</p>
        </header>

        <form class="create-form auth-form" asp-action="Login" asp-controller="Auth" method="post" novalidate>
            <div class="form-field">
                <label class="form-field__label" for="auth-login">Логин</label>
                <input
                    asp-for="Login"
                    id="auth-login"
                    class="form-field__input"
                    placeholder="Ваш логин"
                    autocomplete="username"
                    maxlength="100" />
                @Html.ValidationMessageFor(x => x.Login)
            </div>

            <div class="form-field">
                <label class="form-field__label" for="auth-password">Пароль</label>
                <input
                    asp-for="Password"
                    id="auth-password"
                    type="password"
                    class="form-field__input"
                    placeholder="Пароль"
                    autocomplete="current-password"
                    maxlength="100" />
                @Html.ValidationMessageFor(x => x.Password)
            </div>

            <div class="create-form__actions auth-form__actions">
                <button type="submit" class="create-btn create-btn--primary auth-form__submit">Войти</button>
            </div>
        </form>

        <p class="auth-switch">
            Нет аккаунта?
            <a class="auth-switch__link" asp-controller="Auth" asp-action="Registration">Зарегистрироваться</a>
        </p>
    </article>
</div>
