<div class="color-legend" role="note" aria-label="Цветовая схема задач">
    <p class="color-legend__title">Цвета</p>
    <span class="color-legend__item">
        <span class="color-legend__dot color-legend__dot--urgent" aria-hidden="true"></span>
        Срочная
    </span>
    <span class="color-legend__item">
        <span class="color-legend__dot color-legend__dot--medium" aria-hidden="true"></span>
        Средняя
    </span>
    <span class="color-legend__item">
        <span class="color-legend__dot color-legend__dot--easy" aria-hidden="true"></span>
        Лёгкая
    </span>
    <span class="color-legend__item">
        <span class="color-legend__dot color-legend__dot--done" aria-hidden="true"></span>
        Выполнена
    </span>
    <span class="color-legend__item">
        <span class="color-legend__dot color-legend__dot--overdue" aria-hidden="true"></span>
        Просрочена
    </span>
</div>
