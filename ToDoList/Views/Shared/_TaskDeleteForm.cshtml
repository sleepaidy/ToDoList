@model (int Id, string ReturnAction, string TaskName)

<form asp-controller="Home"
      asp-action="Delete"
      method="post"
      class="task-card__delete-form"
      onsubmit="return confirm('Удалить задачу «@Model.TaskName»?');">
    <input type="hidden" name="id" value="@Model.Id" />
    <input type="hidden" name="returnAction" value="@Model.ReturnAction" />
    <button type="submit"
            class="task-card__delete-btn"
            title="Удалить задачу"
            aria-label="Удалить задачу @Model.TaskName">
        <span aria-hidden="true">×</span>
    </button>
</form>
