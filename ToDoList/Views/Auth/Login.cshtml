@model ToDoList.Models.Auth.LoginViewModel
@{
    ViewData["Title"] = Auth.Login_Page_Title;
}

<div class="auth-page">
    <article class="create-card auth-card" aria-labelledby="login-heading">
        <header class="create-card__header">
            <h1 id="login-heading" class="create-card__title">@Auth.Login_Header_Title</h1>
            <p class="create-card__lead">@Auth.Login_Header_Lead</p>
        </header>

        <form class="create-form auth-form" asp-action="Login" asp-controller="Auth" method="post" novalidate>
            <div class="form-field">
                <label class="form-field__label" for="auth-login">@Auth.Login_Label_Login</label>
                <input
                    asp-for="Login"
                    id="auth-login"
                    class="form-field__input"
                    placeholder="@Auth.Login_Placeholder_Login"
                    autocomplete="username"
                    maxlength="100" />
                @Html.ValidationMessageFor(x => x.Login)
            </div>

            <div class="form-field">
                <label class="form-field__label" for="auth-password">@Auth.Login_Label_Password</label>
                <input
                    asp-for="Password"
                    id="auth-password"
                    type="password"
                    class="form-field__input"
                    placeholder="@Auth.Login_Placeholder_Password"
                    autocomplete="current-password"
                    maxlength="100" />
                @Html.ValidationMessageFor(x => x.Password)
            </div>

            <div class="create-form__actions auth-form__actions">
                <button type="submit" class="create-btn create-btn--primary auth-form__submit">@Auth.Login_Button_Submit</button>
            </div>
        </form>

        <p class="auth-switch">
            @Auth.Login_Switch_Text
            <a class="auth-switch__link" asp-controller="Auth" asp-action="Registration">@Auth.Login_Switch_Link</a>
        </p>
    </article>
</div>
