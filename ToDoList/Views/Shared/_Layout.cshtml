@using System.Globalization
@using ToDoList.Services.Interfaces
@inject IAuthService AuthService
@{
    var currentUser = AuthService.GetUser();
    var avatarUrl = currentUser?.ProfileImage;
    var userInitial = User.Identity?.Name is { Length: > 0 } name ? name[0].ToString().ToUpperInvariant() : "?";
    var htmlLang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<!DOCTYPE html>

<html lang="@htmlLang">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - ToDoList</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/app-style.css" asp-append-version="true" />
    @if (User.Identity?.IsAuthenticated == true)
    {
        <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />
    }

    <link rel="stylesheet" href="~/ToDoList.styles.css" asp-append-version="true" />

</head>

<body class="app-body">

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="notifications" aria-live="polite"></div>
    }

    <header>

        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light app-navbar mb-3">

            <div class="container-fluid app-navbar__inner">

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"

                        aria-expanded="false" aria-label="@Shared.Nav_ToggleMenu">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Home" asp-action="Index">@Shared.Nav_NewTask</a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Home" asp-action="ToDoList">@Shared.Nav_AllTasks</a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Home" asp-action="DoneList">@Shared.Nav_Done</a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Home" asp-action="FailedList">@Shared.Nav_Failed</a>

                        </li>

                    </ul>

                    <ul class="navbar-nav app-navbar__auth">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link app-navbar__user-link"
                                   asp-controller="User"
                                   asp-action="Profile"
                                   title="@Shared.Nav_Profile">
                                    @if (!string.IsNullOrEmpty(avatarUrl))
                                    {
                                        <img src="@avatarUrl" alt="" class="profile-avatar" />
                                    }
                                    else
                                    {
                                        <span class="profile-avatar profile-avatar--placeholder" aria-hidden="true">@userInitial</span>
                                    }
                                    <span class="app-navbar__user-name">@User.Identity.Name</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="LogOut">@Shared.Nav_LogOut</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">@Shared.Nav_LogIn</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Registration">@Shared.Nav_Registration</a>
                            </li>
                        }
                    </ul>

                </div>

            </div>

        </nav>

    </header>



    <div class="container app-shell">

        <div class="app-shell__grid">

            <aside class="app-sidebar" aria-label="@Shared.Sidebar_Label">

                @await Component.InvokeAsync("Dashboard")

            </aside>

            <main class="app-main" role="main">

                @RenderBody()

            </main>

        </div>

    </div>



    <footer class="app-footer">

        <div class="container app-footer__inner">

            <span>@Shared.Footer_Copyright</span>

        </div>

    </footer>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await Html.PartialAsync("_AppLocalization")
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.js"></script>
        <script src="~/js/todo/deadline-notifications.js" asp-append-version="true"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
