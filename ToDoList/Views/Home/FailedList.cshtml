@{
    ViewData["Title"] = "Проваленные задачи";
}

<div class="todo-app-page">
    <article class="page-card" aria-labelledby="failed-heading">
        <header class="page-card__header">
            <h1 id="failed-heading" class="page-card__title">Проваленные задачи</h1>
            <p class="page-card__lead">Дела, которые не удалось завершить в срок</p>
            <span class="page-card__count">1</span>
        </header>

        <ul class="task-list">
            <li class="task-card task-card--failed">
                <div class="task-card__head">
                    <h2 class="task-card__title">Сдать проект в срок</h2>
                </div>
                <p class="task-card__description">Дедлайн прошёл, отчёт не отправлен заказчику.</p>
                <ul class="task-card__meta">
                    <li>
                        <span class="task-card__meta-label">Статус</span>
                        <span class="task-card__pill task-card__pill--failed">Провалена</span>
                    </li>
                    <li>
                        <span class="task-card__meta-label">Категория</span>
                        <span>Работа</span>
                    </li>
                    <li>
                        <span class="task-card__meta-label">Срок</span>
                        <span>15.05.2026</span>
                    </li>
                </ul>
            </li>
        </ul>
    </article>
</div>
