@{
    ViewData["Title"] = Home.Index_Page_Title;
}
@model CreateToDoTaskViewModel

<div class="todo-app-page">
    <article class="create-card" aria-labelledby="create-heading">
        <header class="create-card__header">
            <h1 id="create-heading" class="create-card__title">@Home.Index_Header_Create_Card</h1>
            <p class="create-card__lead">@Home.Index_Header_Create_Card_Lead</p>
        </header>

        <form class="create-form" asp-action="Index" asp-controller="Home" method="post" novalidate>
            <div class="form-row">
                <div class="form-field">
                    <label class="form-field__label" for="task-title">
                        @Home.Index_Label_Name <span class="form-field__required" aria-hidden="true">*</span>
                    </label>
                    <input
                        type="text"
                        id="task-title"
                        name="Name"
                        class="form-field__input"
                        placeholder="@Home.Index_Placeholder_Name"
                        required
                        maxlength="200"
                        autocomplete="off" />
                    @Html.ValidationMessageFor(x => x.Name)
                </div>
                <div class="form-field">
                    <label class="form-field__label" for="task-category">@Home.Index_Label_Category</label>
                    <input
                        type="text"
                        id="task-category"
                        name="Category"
                        class="form-field__input"
                        placeholder="@Home.Index_Placeholder_Category"
                        maxlength="50"
                        list="category-suggestions" />
                    <datalist id="category-suggestions">
                        <option value="@Home.Index_Category_Work"></option>
                        <option value="@Home.Index_Category_Home"></option>
                        <option value="@Home.Index_Category_Health"></option>
                        <option value="@Home.Index_Category_Study"></option>
                    </datalist>
                </div>
            </div>

            <div class="form-field">
                <label class="form-field__label" for="task-description">@Home.Index_Label_Description</label>
                <textarea
                    id="task-description"
                    name="Description"
                    class="form-field__input form-field__textarea"
                    placeholder="@Home.Index_Placeholder_Description"
                    rows="4"
                    maxlength="2000"></textarea>
            </div>

            <div class="form-row form-row--3">
                <div class="form-field">
                    <label class="form-field__label" for="task-due-date">@Home.Index_Label_DeadlineDate</label>
                    <input type="date" id="task-due-date" name="DeadlineDate" class="form-field__input" value="@(Model.DeadlineDate?.ToString("yyyy-MM-dd"))" />
                    @Html.ValidationMessageFor(x => x.DeadlineDate)
                </div>
                <div class="form-field">
                    <label class="form-field__label" for="task-due-time">@Home.Index_Label_DeadlineTime</label>
                    <input type="time" id="task-due-time" name="DeadlineTime" class="form-field__input" value="@(Model.DeadlineTime?.ToString("HH:mm"))" />
                    @Html.ValidationMessageFor(x => x.DeadlineTime)
                </div>
                <div class="form-field">
                    <label class="form-field__label" for="task-important">@Home.Index_Label_Tag</label>
                    <label class="choice-check choice-check--block">
                        <input type="checkbox" name="IsImportant" value="true" id="task-important" class="choice-check__input" />
                        <span class="choice-check__box" aria-hidden="true"></span>
                        <span class="choice-check__text">@Home.Index_Label_Important</span>
                    </label>
                    @Html.ValidationMessageFor(x => x.IsImportant)
                </div>
            </div>

            <div class="form-row">
                <fieldset class="form-field form-field--group">
                    <legend class="form-field__label">@Home.Index_Label_Priority</legend>
                    <div class="choice-group">
                        <label class="choice-pill choice-pill--priority-low">
                            <input type="radio" name="Priority" value="Low" />
                            <span>@Home.Index_Priority_Low</span>
                        </label>
                        <label class="choice-pill choice-pill--priority-medium">
                            <input type="radio" name="Priority" value="Medium" checked />
                            <span>@Home.Index_Priority_Medium</span>
                        </label>
                        <label class="choice-pill choice-pill--priority-high">
                            <input type="radio" name="Priority" value="High" />
                            <span>@Home.Index_Priority_High</span>
                        </label>
                        @Html.ValidationMessageFor(x => x.Priority)
                    </div>
                </fieldset>
            </div>

            <div class="create-form__actions">
                <button type="submit" class="create-btn create-btn--primary">@Home.Index_Button_Create</button>
                <button type="reset" class="create-btn create-btn--secondary">@Home.Index_Button_Reset</button>
            </div>
        </form>
    </article>
</div>
