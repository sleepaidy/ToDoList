@using ToDoList.Enums
@using ToDoList.Models.Entities
@model IReadOnlyList<ToDoItem>
@{
    ViewData["Title"] = "Все задачи";

    string GetPriorityLabel(Priority priority) => priority switch
    {
        Priority.High => "Высокий",
        Priority.Medium => "Средний",
        Priority.Low => "Низкий",
        _ => priority.ToString()
    };

    string GetPriorityPillClass(Priority priority) => priority switch
    {
        Priority.High => "task-card__pill--priority-high",
        Priority.Medium => "task-card__pill--priority-medium",
        Priority.Low => "task-card__pill--priority-low",
        _ => string.Empty
    };

    string GetCardClass(ToDoItem task) => task.IsImportant
        ? "task-card task-card--important"
        : $"task-card task-card--priority-{task.Priority.ToString().ToLower()}";
}

<div class="todo-app-page">
    <article class="page-card" aria-labelledby="all-tasks-heading">
        <header class="page-card__header">
            <h1 id="all-tasks-heading" class="page-card__title">Все задачи</h1>
            <p class="page-card__lead">Список дел, созданных на странице «Новая задача»</p>
            <span class="page-card__count">@Model.Count</span>
        </header>

        @if (Model.Count == 0)
        {
            <p class="page-card__lead">
                Задач пока нет.
                <a asp-controller="Home" asp-action="Index">Создать первую</a>
            </p>
        }
        else
        {
            <ul class="task-list">
                @foreach (var task in Model)
                {
                    <li class="@GetCardClass(task)">
                        <div class="task-card__head">
                            <h2 class="task-card__title">@task.Name</h2>
                            @if (task.IsImportant)
                            {
                                <span class="task-card__badge" title="Важная">!</span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(task.Description))
                        {
                            <p class="task-card__description">@task.Description</p>
                        }

                        <ul class="task-card__meta">
                            <li>
                                <span class="task-card__meta-label">Приоритет</span>
                                <span class="task-card__pill @GetPriorityPillClass(task.Priority)">@GetPriorityLabel(task.Priority)</span>
                            </li>
                            @if (!string.IsNullOrWhiteSpace(task.Category))
                            {
                                <li>
                                    <span class="task-card__meta-label">Категория</span>
                                    <span>@task.Category</span>
                                </li>
                            }
                            @if (task.DeadlineAt.HasValue)
                            {
                                <li>
                                    <span class="task-card__meta-label">Срок</span>
                                    <span>@task.DeadlineAt.Value.ToString("dd.MM.yyyy, HH:mm")</span>
                                </li>
                            }
                        </ul>
                    </li>
                }
            </ul>
        }
    </article>
</div>
