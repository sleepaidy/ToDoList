@using ToDoList.Models.Dtos
@model IReadOnlyList<ToDoTaskDto>
@{
    ViewData["Title"] = "Проваленные задачи";
}

<div class="todo-app-page">
    <article class="page-card" aria-labelledby="failed-heading">
        <header class="page-card__header">
            <h1 id="failed-heading" class="page-card__title">Проваленные задачи</h1>
            <p class="page-card__lead">Дела, которые не удалось завершить в срок</p>
            <span class="page-card__count">@Model.Count</span>
        </header>

        @if (Model.Count == 0)
        {
            <p class="page-card__lead">
                Проваленных задач пока нет.
                <a asp-controller="Home" asp-action="Index">Создать задачу</a>
            </p>
        }
        else
        {
            <ul class="task-list">
                @foreach (var task in Model)
                {
                    <li class="task-card task-card--failed">
                        <div class="task-card__head">
                            <h2 class="task-card__title">@task.Name</h2>
                            <div class="task-card__actions">
                                @await Html.PartialAsync("_TaskCompleteForm", (task.Id, task.Name))
                                @await Html.PartialAsync("_TaskDeleteForm", (task.Id, "FailedList", task.Name))
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(task.Description))
                        {
                            <p class="task-card__description">@task.Description</p>
                        }

                        <ul class="task-card__meta">
                            <li>
                                <span class="task-card__meta-label">Статус</span>
                                <span class="task-card__pill task-card__pill--failed">Провалена</span>
                            </li>
                            @if (!string.IsNullOrWhiteSpace(task.Category))
                            {
                                <li>
                                    <span class="task-card__meta-label">Категория</span>
                                    <span>@task.Category</span>
                                </li>
                            }
                            @if (task.DeadlineAt.HasValue)
                            {
                                <li>
                                    <span class="task-card__meta-label">Срок</span>
                                    <span>@task.DeadlineAt.Value.ToString("dd.MM.yyyy")</span>
                                </li>
                            }
                        </ul>
                    </li>
                }
            </ul>
        }
    </article>
</div>
