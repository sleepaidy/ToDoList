@using System.Globalization
@using System.Text.Json
@using ToDoList.Localization
@{
    var l10n = new
    {
        locale = CultureInfo.CurrentUICulture.Name,
        months = new[]
        {
            Shared.Js_Month_Jan,
            Shared.Js_Month_Feb,
            Shared.Js_Month_Mar,
            Shared.Js_Month_Apr,
            Shared.Js_Month_May,
            Shared.Js_Month_Jun,
            Shared.Js_Month_Jul,
            Shared.Js_Month_Aug,
            Shared.Js_Month_Sep,
            Shared.Js_Month_Oct,
            Shared.Js_Month_Nov,
            Shared.Js_Month_Dec
        },
        statusActive = Shared.Js_Status_Active,
        statusDone = Shared.Js_Status_Done,
        statusFailed = Shared.Js_Status_Failed,
        tasksCount = Shared.Js_TasksCount,
        tasksOn = Shared.Js_TasksOn,
        taskOrderError = Shared.Js_TaskOrder_Error
    };
}
<script id="app-localization" type="application/json">@Html.Raw(JsonSerializer.Serialize(l10n))</script>
