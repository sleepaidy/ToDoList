<!DOCTYPE html>

<html lang="ru">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - ToDoList</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/app-style.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/ToDoList.styles.css" asp-append-version="true" />

</head>

<body class="app-body">

    <header>

        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light app-navbar mb-3">

            <div class="container-fluid app-navbar__inner">

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"

                        aria-expanded="false" aria-label="Открыть меню">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Home" asp-action="Index">Новая задача</a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Home" asp-action="ToDoList">Все задачи</a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Home" asp-action="DoneList">Выполненные</a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link" asp-controller="Home" asp-action="FailedList">Проваленные</a>

                        </li>

                    </ul>

                </div>

            </div>

        </nav>

    </header>



    <div class="container app-shell">

        <div class="app-shell__grid">

            <aside class="app-sidebar" aria-label="Панель управления">

                @await Component.InvokeAsync("Dashboard")

            </aside>

            <main class="app-main" role="main">

                @RenderBody()

            </main>

        </div>

    </div>



    <footer class="app-footer">

        <div class="container app-footer__inner">

            <span>&copy; 2026 — ToDoList</span>

        </div>

    </footer>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>

