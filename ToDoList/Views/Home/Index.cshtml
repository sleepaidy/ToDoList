@{
    ViewData["Title"] = "Новая задача";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home-style.css" asp-append-version="true" />
}

<div class="todo-app-page">
    <article class="create-card" aria-labelledby="create-heading">
        <header class="create-card__header">
            <h1 id="create-heading" class="create-card__title">Новая задача</h1>
            <p class="create-card__lead">Заполните поля ниже</p>
        </header>

        <form class="create-form" action="#" method="post" novalidate>
            <div class="form-field">
                <label class="form-field__label" for="task-title">
                    Название <span class="form-field__required" aria-hidden="true">*</span>
                </label>
                <input
                    type="text"
                    id="task-title"
                    name="Title"
                    class="form-field__input"
                    placeholder="Например: Подготовить отчёт"
                    required
                    maxlength="200"
                    autocomplete="off" />
            </div>

            <div class="form-field">
                <label class="form-field__label" for="task-description">Описание</label>
                <textarea
                    id="task-description"
                    name="Description"
                    class="form-field__input form-field__textarea"
                    placeholder="Детали, ссылки, заметки…"
                    rows="4"
                    maxlength="2000"></textarea>
            </div>

            <div class="form-row">
                <div class="form-field">
                    <label class="form-field__label" for="task-due-date">Срок</label>
                    <input type="date" id="task-due-date" name="DueDate" class="form-field__input" />
                </div>
                <div class="form-field">
                    <label class="form-field__label" for="task-due-time">Время</label>
                    <input type="time" id="task-due-time" name="DueTime" class="form-field__input" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-field">
                    <label class="form-field__label" for="task-priority">Приоритет</label>
                    <select id="task-priority" name="Priority" class="form-field__input form-field__select">
                        <option value="Low">Низкий</option>
                        <option value="Medium" selected>Средний</option>
                        <option value="High">Высокий</option>
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-field__label" for="task-category">Категория</label>
                    <input
                        type="text"
                        id="task-category"
                        name="Category"
                        class="form-field__input"
                        placeholder="Работа, дом…"
                        maxlength="50"
                        list="category-suggestions" />
                    <datalist id="category-suggestions">
                        <option value="Работа"></option>
                        <option value="Дом"></option>
                        <option value="Здоровье"></option>
                        <option value="Учёба"></option>
                    </datalist>
                </div>
            </div>

            <fieldset class="form-field form-field--group">
                <legend class="form-field__label">Статус</legend>
                <div class="choice-group">
                    <label class="choice-pill">
                        <input type="radio" name="Status" value="Active" checked />
                        <span>Активная</span>
                    </label>
                    <label class="choice-pill">
                        <input type="radio" name="Status" value="Done" />
                        <span>Выполнена</span>
                    </label>
                </div>
            </fieldset>

            <div class="form-field">
                <label class="choice-check">
                    <input type="checkbox" name="IsImportant" value="true" class="choice-check__input" />
                    <span class="choice-check__box" aria-hidden="true"></span>
                    <span class="choice-check__text">Отметить как важную</span>
                </label>
            </div>

            <div class="create-form__actions">
                <button type="submit" class="create-btn create-btn--primary">Создать задачу</button>
                <button type="reset" class="create-btn create-btn--secondary">Очистить</button>
            </div>
        </form>
    </article>
</div>
